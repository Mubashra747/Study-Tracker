<?xml version="1.0" encoding="utf-8"?>
<!--

  layout_carousel.xml  —  RECENT SUBJECTS CAROUSEL

  L8   HorizontalScrollView — scrolls left-to-right
         independently of the main vertical NestedScrollView.

-->
<HorizontalScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/hScrollCarousel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/carouselRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <!-- ── Subject Card: Mathematics ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardMath"
            android:layout_width="130dp"
            android:layout_height="150dp"
            android:layout_marginEnd="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📐" android:textSize="32sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Mathematics" android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" android:textColor="@color/colorTextPrimary"
                    android:gravity="center" android:layout_marginTop="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="2h 30m" android:textSize="11sp" android:textColor="@color/colorPrimary"
                    android:layout_marginTop="2dp"/>
                <ProgressBar android:layout_width="match_parent" android:layout_height="4dp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:progress="75" android:progressTint="@color/colorPrimary"
                    android:progressBackgroundTint="@color/colorDivider"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Subject Card: Physics ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardPhysics"
            android:layout_width="130dp"
            android:layout_height="150dp"
            android:layout_marginEnd="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚡" android:textSize="32sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Physics" android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" android:textColor="@color/colorTextPrimary"
                    android:gravity="center" android:layout_marginTop="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1h 45m" android:textSize="11sp" android:textColor="@color/colorChart2"
                    android:layout_marginTop="2dp"/>
                <ProgressBar android:layout_width="match_parent" android:layout_height="4dp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:progress="55" android:progressTint="@color/colorChart2"
                    android:progressBackgroundTint="@color/colorDivider"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Subject Card: CS ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCS"
            android:layout_width="130dp"
            android:layout_height="150dp"
            android:layout_marginEnd="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💻" android:textSize="32sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CS" android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" android:textColor="@color/colorTextPrimary"
                    android:gravity="center" android:layout_marginTop="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="3h 10m" android:textSize="11sp" android:textColor="@color/colorChart3"
                    android:layout_marginTop="2dp"/>
                <ProgressBar android:layout_width="match_parent" android:layout_height="4dp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:progress="90" android:progressTint="@color/colorChart3"
                    android:progressBackgroundTint="@color/colorDivider"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Subject Card: Chemistry ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardChem"
            android:layout_width="130dp"
            android:layout_height="150dp"
            android:layout_marginEnd="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🧪" android:textSize="32sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Chemistry" android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" android:textColor="@color/colorTextPrimary"
                    android:gravity="center" android:layout_marginTop="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1h 00m" android:textSize="11sp" android:textColor="@color/colorChart4"
                    android:layout_marginTop="2dp"/>
                <ProgressBar android:layout_width="match_parent" android:layout_height="4dp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:progress="40" android:progressTint="@color/colorChart4"
                    android:progressBackgroundTint="@color/colorDivider"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Subject Card: English ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEnglish"
            android:layout_width="130dp"
            android:layout_height="150dp"
            android:layout_marginEnd="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                android:orientation="vertical" android:gravity="center" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📖" android:textSize="32sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="English" android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" android:textColor="@color/colorTextPrimary"
                    android:gravity="center" android:layout_marginTop="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0h 45m" android:textSize="11sp" android:textColor="@color/colorChart5"
                    android:layout_marginTop="2dp"/>
                <ProgressBar android:layout_width="match_parent" android:layout_height="4dp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:progress="30" android:progressTint="@color/colorChart5"
                    android:progressBackgroundTint="@color/colorDivider"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</HorizontalScrollView>
