<?xml version="1.0" encoding="utf-8"?>
<!--
    Chip state selector for subject tag chips.
    Selected → primary fill (white text)
    Pressed  → lighter primary tint
    Default  → light indigo fill with border
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true">
        <shape>
            <solid android:color="@color/colorPrimary"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/colorPrimaryLight"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/colorChipBg"/>
            <corners android:radius="16dp"/>
            <stroke android:width="1dp" android:color="@color/colorChipBorder"/>
        </shape>
    </item>

</selector>
