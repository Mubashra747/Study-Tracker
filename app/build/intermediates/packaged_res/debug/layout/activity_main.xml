<?xml version="1.0" encoding="utf-8"?>
<!--

 activity_main.xml  —  DASHBOARD HOST

  L1   CoordinatorLayout  — root; coordinates AppBar + scroll
  L5   FrameLayout        — notification hub (bell + red badge)
  L3   LinearLayout       — bottom nav; 5 items each weight="1"



-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".MainActivity">

    <!--
         L1 — AppBarLayout with CollapsingToolbarLayout
         Collapses when NestedScrollView scrolls upward.
 -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:fitsSystemWindows="true"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="true"
            app:contentScrim="@color/colorPrimary"
            app:expandedTitleMarginStart="16dp"
            app:expandedTitleMarginBottom="72dp"
            app:collapsedTitleTextAppearance="@style/TextAppearance.StudyTracker.CollapsingTitle"
            app:expandedTitleTextAppearance="@style/TextAppearance.StudyTracker.CollapsingTitle"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:title="@string/app_name">

            <!-- Expanded gradient header background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_primary_gradient"
                app:layout_collapseMode="parallax"/>

            <!-- Expanded greeting text (disappears when collapsed) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="117dp"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="60dp"
                app:layout_collapseMode="parallax">

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginTop="2dp"
                    android:text="@string/dashboard_subtitle"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Pinned toolbar (always visible) -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

                <!-- Right-side action icons inside toolbar -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:orientation="horizontal"
                    android:paddingEnd="8dp"
                    android:gravity="center_vertical">

                    <!--
                         L5 — FrameLayout NOTIFICATION HUB
                         Bell icon + red badge stacked top|end
                          -->
                    <FrameLayout
                        android:id="@+id/frameNotifHub"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="4dp">

                        <!-- Bell icon centred in frame -->
                        <ImageView
                            android:id="@+id/ivBell"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_notification"
                            android:contentDescription="@string/cd_notification"/>

                        <!-- Red count badge — stacked top|end -->
                        <TextView
                            android:id="@+id/tvBadgeCount"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:background="@drawable/bg_badge"
                            android:text="3"
                            android:textColor="@color/white"
                            android:textSize="9sp"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"/>

                    </FrameLayout>

                    <!-- Settings gear -->
                    <ImageView
                        android:id="@+id/ivToolbarSettings"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_settings"
                        android:tint="@color/white"
                        android:contentDescription="@string/cd_settings"/>

                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/greeting_morning"
                android:textColor="@color/white"
                android:textSize="20sp" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!--
         Scrollable dashboard content (includes all sections)
         -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="68dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <include layout="@layout/content_dashboard"/>

    </androidx.core.widget.NestedScrollView>

    <!--
         L3 — LinearLayout BOTTOM NAVIGATION BAR
         5 items, each layout_weight="1" → equal widths
         -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="8dp">

        <!-- Item 1 — Dashboard (selected) -->
        <LinearLayout
            android:id="@+id/navItemDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp"
            android:background="@drawable/selector_bottom_nav">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_dashboard"
                android:tint="@color/colorPrimary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_dashboard"
                android:textSize="10sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Item 2 — Timer -->
        <LinearLayout
            android:id="@+id/navItemTimer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp"
            android:background="@drawable/selector_bottom_nav">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_timer"
                android:tint="@color/colorBottomNavUnselected"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_timer"
                android:textSize="10sp"
                android:textColor="@color/colorBottomNavUnselected"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Item 3 — Analytics -->
        <LinearLayout
            android:id="@+id/navItemAnalytics"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp"
            android:background="@drawable/selector_bottom_nav">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_analytics"
                android:tint="@color/colorBottomNavUnselected"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_analytics"
                android:textSize="10sp"
                android:textColor="@color/colorBottomNavUnselected"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Item 4 — History -->
        <LinearLayout
            android:id="@+id/navItemHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp"
            android:background="@drawable/selector_bottom_nav">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_history"
                android:tint="@color/colorBottomNavUnselected"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_history"
                android:textSize="10sp"
                android:textColor="@color/colorBottomNavUnselected"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Item 5 — Settings -->
        <LinearLayout
            android:id="@+id/navItemSettings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="6dp"
            android:background="@drawable/selector_bottom_nav">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                android:tint="@color/colorBottomNavUnselected"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_settings"
                android:textSize="10sp"
                android:textColor="@color/colorBottomNavUnselected"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
