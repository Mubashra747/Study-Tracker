<?xml version="1.0" encoding="utf-8"?>
<!--

  activity_analytics.xml  —  ANALYTICS SCREEN

  L9   Weekly period display

-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/analyticsToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorPrimary"
            app:title="@string/analytics_title"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Title for period -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/analytics_weekly"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginBottom="16dp"/>

            <!-- Metric cards row 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView android:layout_width="0dp"
                    android:layout_height="100dp" android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp" app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/analytics_score" android:textSize="28sp"
                            android:fontFamily="sans-serif-medium" android:textColor="@color/colorPrimary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/analytics_score_label" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:layout_width="0dp"
                    android:layout_height="100dp" android:layout_weight="1"
                    app:cardCornerRadius="12dp" app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/analytics_hours" android:textSize="28sp"
                            android:fontFamily="sans-serif-medium" android:textColor="@color/colorAccent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/analytics_hours_label" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Bar chart card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp" app:cardElevation="4dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/analytics_chart_title"
                        android:textSize="15sp" android:fontFamily="sans-serif-medium"
                        android:textColor="@color/colorTextPrimary" android:paddingBottom="12dp"/>

                    <!-- Visual bar chart (weights represent bar heights, gravity=bottom) -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="120dp"
                        android:orientation="horizontal" android:gravity="bottom" android:paddingTop="8dp">

                        <!-- Mon -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="bottom|center_horizontal">
                            <View android:layout_width="20dp" android:layout_height="70dp"
                                android:background="@drawable/bg_primary_gradient"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="M" android:textSize="10sp"
                                android:textColor="@color/colorTextSecondary" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <!-- Tue -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="bottom|center_horizontal">
                            <View android:layout_width="20dp" android:layout_height="90dp"
                                android:background="@drawable/bg_primary_gradient"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="T" android:textSize="10sp"
                                android:textColor="@color/colorTextSecondary" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <!-- Wed -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="bottom|center_horizontal">
                            <View android:layout_width="20dp" android:layout_height="50dp"
                                android:background="@drawable/bg_primary_gradient"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="W" android:textSize="10sp"
                                android:textColor="@color/colorTextSecondary" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <!-- Thu -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="bottom|center_horizontal">
                            <View android:layout_width="20dp" android:layout_height="100dp"
                                android:background="@drawable/bg_primary_gradient"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="T" android:textSize="10sp"
                                android:textColor="@color/colorTextSecondary" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <!-- Fri -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="bottom|center_horizontal">
                            <View android:layout_width="20dp" android:layout_height="80dp"
                                android:background="@drawable/bg_primary_gradient"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="F" android:textSize="10sp"
                                android:textColor="@color/colorTextSecondary" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <!-- Sat -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="bottom|center_horizontal">
                            <View android:layout_width="20dp" android:layout_height="40dp"
                                android:background="@drawable/bg_primary_gradient"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="S" android:textSize="10sp"
                                android:textColor="@color/colorTextSecondary" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <!-- Sun -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="bottom|center_horizontal">
                            <View android:layout_width="20dp" android:layout_height="60dp"
                                android:background="@drawable/bg_primary_gradient"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="S" android:textSize="10sp"
                                android:textColor="@color/colorTextSecondary" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Subject breakdown card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp" app:cardElevation="4dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/analytics_breakdown_title"
                        android:textSize="15sp" android:fontFamily="sans-serif-medium"
                        android:textColor="@color/colorTextPrimary" android:paddingBottom="12dp"/>

                    <!-- CS -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="💻 CS" android:textSize="13sp"
                            android:textColor="@color/colorTextPrimary"/>
                        <ProgressBar android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="5" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progress="40" android:progressTint="@color/colorPrimary"
                            android:progressBackgroundTint="@color/colorDivider"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="40%" android:textSize="12sp"
                            android:textColor="@color/colorPrimary" android:gravity="end"/>
                    </LinearLayout>

                    <!-- Math -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="📐 Math" android:textSize="13sp"
                            android:textColor="@color/colorTextPrimary"/>
                        <ProgressBar android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="5" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progress="28" android:progressTint="@color/colorAccent"
                            android:progressBackgroundTint="@color/colorDivider"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="28%" android:textSize="12sp"
                            android:textColor="@color/colorAccent" android:gravity="end"/>
                    </LinearLayout>

                    <!-- Physics -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="⚡ Physics" android:textSize="13sp"
                            android:textColor="@color/colorTextPrimary"/>
                        <ProgressBar android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="5" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progress="20" android:progressTint="@color/colorWarning"
                            android:progressBackgroundTint="@color/colorDivider"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="20%" android:textSize="12sp"
                            android:textColor="@color/colorWarning" android:gravity="end"/>
                    </LinearLayout>

                    <!-- Chemistry -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="2" android:text="🧪 Chem" android:textSize="13sp"
                            android:textColor="@color/colorTextPrimary"/>
                        <ProgressBar android:layout_width="0dp" android:layout_height="6dp"
                            android:layout_weight="5" style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progress="12" android:progressTint="@color/colorError"
                            android:progressBackgroundTint="@color/colorDivider"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="12%" android:textSize="12sp"
                            android:textColor="@color/colorError" android:gravity="end"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
